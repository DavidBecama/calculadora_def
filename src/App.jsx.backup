      { id: "prestamo", nombre: "Préstamo hipotecario", tipo: "cuantia", subtipos: ["vivienda", "otro"], reducciones: { vivienda: 46.56, otro: 28.75 }, validado: true },
      { id: "cancelacion", nombre: "Cancelación de hipoteca", tipo: "fijo", tarifa: 30.05, validado: true },
      { id: "novacion", nombre: "Novación hipotecaria", tipo: "especial", nota: "Doc sin cuantía (30,05€) por Ley 41/2007", tarifa: 30.05, validado: false },
      { id: "subrogacion", nombre: "Subrogación de acreedor", tipo: "cuantia", reducciones: { _default: 52.5 }, validado: false },
      { id: "extincion", nombre: "Extinción de condominio", tipo: "cuantia", reducciones: { _default: 5 }, validado: true },
      { id: "arras", nombre: "Contrato de arras", tipo: "cuantia", reducciones: { _default: 5 }, validado: true },
      { id: "opcion_compra", nombre: "Opción de compra", tipo: "cuantia", reducciones: { _default: 5 }, validado: true },
      { id: "obra_nueva", nombre: "Declaración de obra nueva", tipo: "cuantia", reducciones: { _default: 5 }, validado: true },
      { id: "division_h", nombre: "División horizontal", tipo: "cuantia", reducciones: { _default: 5 }, validado: true },
      { id: "acta_lcci", nombre: "Acta de transparencia (LCCI)", tipo: "especial", nota: "Regulación específica 2019", validado: false },
      { id: "acta_fijacion", nombre: "Acta de fijación de saldo", tipo: "fijo", tarifa: 36.06, validado: true },
    ]
  },
  {
    id: "sucesiones", nombre: "Sucesiones", icon: "📜",
    servicios: [
      { id: "testamento", nombre: "Testamento", tipo: "fijo", tarifa: 30.05, validado: true },
      { id: "testamento_vital", nombre: "Testamento vital", tipo: "fijo", tarifa: 30.05, validado: true },
      { id: "herederos", nombre: "Declaración de herederos", tipo: "fijo", tarifa: 30.05, validado: true },
      { id: "herencia", nombre: "Aceptación de herencia", tipo: "cuantia", reducciones: { _default: 5 }, validado: true },
      { id: "renuncia_h", nombre: "Renuncia de herencia", tipo: "fijo", tarifa: 30.05, validado: true },
      { id: "donacion", nombre: "Donación", tipo: "cuantia", reducciones: { _default: 5 }, validado: true },
      { id: "adicion", nombre: "Adición de herencia", tipo: "cuantia", reducciones: { _default: 5 }, validado: false },
      { id: "legado", nombre: "Entrega de legados", tipo: "cuantia", reducciones: { _default: 5 }, validado: false },
      { id: "cert_europeo", nombre: "Certificado sucesorio europeo", tipo: "fijo", tarifa: 30.05, validado: false },
    ]
  },
  {
    id: "mercantil", nombre: "Mercantil", icon: "🏢",
    servicios: [
      { id: "const_sociedad", nombre: "Constitución de sociedad", tipo: "cuantia", reducciones: { _default: 5 }, validado: true },
      { id: "const_srl_tel", nombre: "Constitución SRL telemática", tipo: "especial", nota: "150€ (capital≥3.100€) ó 60€ (capital<3.100€)", validado: true },
      { id: "cv_participaciones", nombre: "Compraventa participaciones", tipo: "cuantia", reducciones: { _default: 5 }, validado: true },
      { id: "aumento_capital", nombre: "Aumento de capital", tipo: "cuantia", reducciones: { _default: 5 }, validado: true },
      { id: "reduccion_capital", nombre: "Reducción de capital", tipo: "cuantia", reducciones: { _default: 5 }, validado: true },
      { id: "disolucion", nombre: "Disolución/liquidación sociedad", tipo: "cuantia", reducciones: { _default: 5 }, validado: true },
      { id: "cese_nomb", nombre: "Cese y nombramiento administrador", tipo: "fijo", tarifa: 30.05, validado: true },
      { id: "modif_estatutos", nombre: "Modificación de estatutos", tipo: "fijo", tarifa: 30.05, validado: true },
      { id: "elev_publica", nombre: "Elevación a público", tipo: "fijo", tarifa: 30.05, validado: true },
      { id: "acta_junta", nombre: "Acta notarial de Junta", tipo: "fijo", tarifa: 36.06, validado: false },
    ]
  },
  {
    id: "familia", nombre: "Familia", icon: "👨‍👩‍👧",
    servicios: [
      { id: "matrimonio", nombre: "Matrimonio", tipo: "fijo", tarifa: 30.05, validado: true },
      { id: "capit_antes", nombre: "Capitulaciones (antes matrim.)", tipo: "fijo", tarifa: 30.05, validado: true },
      { id: "capit_despues", nombre: "Capitulaciones (después matrim.)", tipo: "cuantia", reducciones: { _default: 5 }, validado: true },
      { id: "divorcio", nombre: "Divorcio", tipo: "cuantia", reducciones: { _default: 5 }, validado: true },
      { id: "pareja", nombre: "Pareja de hecho", tipo: "fijo", tarifa: 30.05, validado: true },
      { id: "disol_pareja", nombre: "Disolución pareja de hecho", tipo: "fijo", tarifa: 30.05, validado: true },
      { id: "emancipacion", nombre: "Emancipación", tipo: "fijo", tarifa: 30.05, validado: true },
      { id: "tutor", nombre: "Nombramiento de tutor", tipo: "fijo", tarifa: 30.05, validado: false },
      { id: "autocuratela", nombre: "Autocuratela", tipo: "fijo", tarifa: 30.05, validado: false },
    ]
  },
  {
    id: "poderes", nombre: "Poderes", icon: "✍️",
    servicios: [
      { id: "poder_general", nombre: "Poder general", tipo: "poder", validado: true },
      { id: "poder_especial", nombre: "Poder especial", tipo: "poder", validado: true },
      { id: "poder_pleitos", nombre: "Poder para pleitos", tipo: "poder", validado: true },
      { id: "poder_preventivo", nombre: "Poder preventivo", tipo: "poder", validado: true },
      { id: "poder_mercantil", nombre: "Poder general mercantil", tipo: "poder", validado: true },
      { id: "ratificacion", nombre: "Ratificación", tipo: "fijo", tarifa: 30.05, validado: true },
      { id: "revocacion", nombre: "Revocación de poder", tipo: "fijo", tarifa: 30.05, validado: true },
      { id: "sustitucion", nombre: "Sustitución de poder", tipo: "fijo", tarifa: 30.05, validado: false },
    ]
  },
  {
    id: "actas", nombre: "Actas", icon: "📋",
    servicios: [
      { id: "acta_manif", nombre: "Acta de manifestaciones", tipo: "fijo", tarifa: 36.06, validado: true },
      { id: "acta_presencia", nombre: "Acta de presencia", tipo: "fijo", tarifa: 36.06, validado: true },
      { id: "acta_notif", nombre: "Acta de notificación", tipo: "fijo", tarifa: 36.06, validado: true },
      { id: "acta_notor", nombre: "Acta de notoriedad", tipo: "fijo", tarifa: 36.06, validado: false },
      { id: "acta_protoc", nombre: "Acta de protocolización", tipo: "fijo", tarifa: 36.06, validado: false },
      { id: "acta_deposito", nombre: "Acta de depósito", tipo: "fijo", tarifa: 36.06, validado: false },
      { id: "acta_sorteo", nombre: "Acta de sorteo", tipo: "fijo", tarifa: 36.06, validado: false },
    ]
  },
  {
    id: "adicionales", nombre: "Otros servicios", icon: "📎",
    servicios: [
      { id: "polizas", nombre: "Pólizas", tipo: "cuantia", reducciones: { _default: 0 }, nota: "Descuento libre", validado: false },
      { id: "legitimaciones", nombre: "Legitimaciones de firma", tipo: "legitimacion", validado: true },
      { id: "testimonios", nombre: "Testimonios", tipo: "testimonio", validado: true },
